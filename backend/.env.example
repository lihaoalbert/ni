# ===== LLM 配置 =====
# Provider: claude | deepseek
LLM_PROVIDER=claude

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-xxx
CLAUDE_MODEL_MAIN=claude-sonnet-4-6
CLAUDE_MODEL_LIGHT=claude-haiku-4-5-20251001
CACHE_CONTROL_ENABLED=true

# Day 6 — 稳定性
LLM_TIMEOUT_SECONDS=30
LLM_IDLE_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=3
# 日志：1 = JSON 输出（生产 ELK / Loki），0 = human-readable
LOG_JSON=0

# Phase 1 — 记忆管道（默认 off,生产改 true 启用）
MEMORY_PIPELINE_ENABLED=false

# DeepSeek（生产备选，OpenAI 兼容协议）
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ===== 应用配置 =====
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# ===== 数据库 =====
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/companion_ai

# ===== 向量库 =====
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
# Phase 2 Loop 4c — Memory Backend 开关
#   inmemory: 进程内 dict,无外部依赖(默认,CI/单测/本地开发)
#   qdrant:   向量库语义检索,需 Qdrant 实例 + embedding 模型
MEMORY_BACKEND=inmemory
QDRANT_COLLECTION=memory_facts

# Phase 2 Loop 4b — Embedding 配置(qdrant 模式时生效)
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DEVICE=cpu

# ===== 缓存 =====
REDIS_URL=redis://localhost:6379/0

# ===== 语音 (Phase 2 Loop 5 + Loop 10.3) =====
# Provider: mock | volcengine
TTS_PROVIDER=mock
STT_PROVIDER=mock
# 火山引擎
# TTS 用新版 openspeech V3 — 极简鉴权(只需 API Key + resource_id 模型选择器)
#   API Key: https://console.volcengine.com/speech/new/setting/apikeys
#   模型:    https://console.volcengine.com/speech/new/setting/activate 开通 seed-tts-2.0
# STT 仍用旧版 openspeech V1
#   AppID/AccessKey/SecretKey: https://console.volcengine.com/speech/service/10035
VOLC_API_KEY=
VOLC_RESOURCE_ID=seed-tts-2.0
VOLC_DEFAULT_VOICE=BV005_streaming
VOLC_TTS_ENDPOINT=https://openspeech.bytedance.com/api/v3/tts/unidirectional
VOLC_APP_ID=
VOLC_ACCESS_KEY=
VOLC_SECRET_KEY=
VOLC_STT_ENDPOINT=https://openspeech.bytedance.com/api/v1/asr
VOLC_CLUSTER=volcano_tts
# TTS 缓存后端: memory (进程内 LRU,默认) | redis (多 worker 共享)
TTS_CACHE_BACKEND=memory
TTS_CACHE_MAX_SIZE=128
# redis 后端用:key TTL + key 前缀
TTS_CACHE_TTL_SECONDS=604800
TTS_CACHE_KEY_PREFIX=tts:
